# 从 local.nev 复制来作为模板,后续会做适当修改以适配 cuda 118 版本 --- IGNORE ---

DOCKER_FILE=docker/cuda-118.Dockerfile
IMAGE_NAME=object-rel-nav:cu118
CONTAINER_NAME=object-rel-nav-cu118

# 本地项目地址和资源地址。
REPO_DIR=/data/user_data/xieziyang/object-rel-nav
HF_HOME_DIR=/data/user_data/xieziyang/my_hf_home/hf_object_rel_nav
WHEELS_DIR=/data/shared/wheels/

# Data source paths on the host.
HM3D_IIN_VAL_SRC=/data/shared/datasets/objectreact_hm3d_iin/evaluation/hm3d_iin_val
MAPS_VIA_ALT_GOAL_SRC=/data/shared/datasets/objectreact_hm3d_iin/evaluation/maps_via_alt_goal
HM3D_V02_VAL_SRC=/data/shared/datasets/habitat_data/versioned_data/hm3d-0.2/hm3d/val

# Model source paths on the host.
DEPTH_ANYTHING_METRIC_DEPTH_INDOOR_SRC=/data/shared/open_source_weights/depth_anything_tango/checkpoints_metric_depth/depth_anything_metric_depth_indoor.pt
DEPTH_ANYTHING_VITL14_SRC=/data/shared/open_source_weights/depth_anything_tango/checkpoints/depth_anything_vitl14.pth
FASTSAM_MODEL_SRC=/data/shared/open_source_weights/FastSAM-s.pt
CLIP_VIT_B_32_SRC=/data/shared/open_source_weights/clip/ViT-B-32.pt
